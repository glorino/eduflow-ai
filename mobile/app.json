{
  "expo": {
    "name": "EduFlow AI",
    "slug": "eduflow-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eduflow.ai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "com.eduflow.ai"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-notifications"]
  }
}
